# Copy to .env.local and fill in. Vercel: set via dashboard or `vercel env add`.

# --- Resend transactional email (https://resend.com) ---
# Sign up free, create an API key, paste below.
RESEND_API_KEY=

# Default Resend sandbox FROM (until taiyoml.com domain is verified in Resend dashboard).
# Once domain is verified, swap to e.g. "TaiyoML <noreply@taiyoml.com>".
RESEND_FROM=TaiyoML <onboarding@resend.dev>

# Internal address that receives contact-form submissions and download-request notifications.
CONTACT_TO=dipam@taiyoml.com

# --- Download token signing ---
# Random 32+ char secret used to HMAC-sign download links. Rotate to invalidate
# all outstanding links. Generate with: openssl rand -base64 48
DOWNLOAD_SECRET=

# --- Public site URL ---
# Used to build absolute download links in outgoing emails.
# Local dev: http://localhost:3000 ; Production: https://taiyoml.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
